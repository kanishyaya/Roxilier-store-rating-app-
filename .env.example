# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=storereviews

# ── Backend ───────────────────────────────────────────────────────────────────
# Must be a long, random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# ── Frontend (build-time) ─────────────────────────────────────────────────────
# URL the browser will call — for local Docker, keep this as-is.
# For production, set this to your public backend URL (e.g. https://api.example.com/api)
VITE_API_URL=http://localhost:6001/api
